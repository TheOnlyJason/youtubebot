# Copy to `.env.local` (gitignored). Never put real secrets in this file.
#
# For AI skit scripts + server TTS, add to .env.local only:
#   OPENAI_API_KEY
#
# For music lyrics + Lyria 3 song generation (same key):
#   GEMINI_API_KEY
# Get a key at https://aistudio.google.com/apikey
# Lyria models: lyria-3-clip-preview (30s), lyria-3-pro-preview (full song)
# LYRIA_MODEL=lyria-3-clip-preview
# Create a key at https://platform.openai.com/api-keys
#
# If render fails with spawn ffmpeg ENOENT, set the full path to ffmpeg.exe (Windows) or ffmpeg binary:
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
#
# Optional overrides (safe defaults below — override in .env.local if needed):
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_SCRIPT_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
OPENAI_TTS_MODEL=tts-1
OPENAI_IMAGE_MODEL=dall-e-3
# Default: faster 720p. For max quality: sora-2-pro + 1080x1920
OPENAI_VIDEO_MODEL=sora-2
OPENAI_VIDEO_SIZE=720x1280
# OPENAI_VIDEO_MAX_WAIT_MS=1800000
# OPENAI_VIDEO_POLL_MS=10000

# Optional: free Pexels API key for real stock video clips per scene (https://www.pexels.com/api/)
# PEXELS_API_KEY=

# Skip rights checkbox + human review checklist before render (local trusted workflow)
# NEXT_PUBLIC_FAST_MODE=true
