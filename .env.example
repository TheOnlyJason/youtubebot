# Copy to `.env.local` (gitignored). Never put real secrets in this file.
#
# For AI script + server TTS, add to .env.local only:
#   OPENAI_API_KEY
# Create a key at https://platform.openai.com/api-keys
#
# If render fails with spawn ffmpeg ENOENT, set the full path to ffmpeg.exe (Windows) or ffmpeg binary:
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
#
# Optional overrides (safe defaults below — override in .env.local if needed):
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_SCRIPT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
